# Example environment for the local-vs-cloud scoring head-to-head (scripts/local_vs_cloud.py).
#
# Copy to `.env` (which is gitignored) and fill in your own keys. NEVER commit real keys.
# The runner reads these by NAME from the environment; a provider whose key is unset is SKIPPED with
# a loud log, so a partial-key run still works. ONLY synthetic / de-identified transcripts are ever
# sent to these endpoints — the PHI guard (src/aivmt/cloud/provenance.py) hard-refuses real-data dirs.
#
# DeepSeek (api.deepseek.com) — AMTES/Liu 2025 used DeepSeek-V2.5; model deepseek-chat = V3 (#1 comparator)
DEEPSEEK_API_KEY=

# Alibaba DashScope OpenAI-compatible mode (qwen-max) — AMTES also used Qwen-Max
DASHSCOPE_API_KEY=

# OpenAI (gpt-4o) — ECOSBot GPT-4o communication-subdomain ICC collapse comparator
OPENAI_API_KEY=
