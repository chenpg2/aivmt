diff --git a/main/application.cc b/main/application.cc
index e83d90a..974a3d4 100644
--- a/main/application.cc
+++ b/main/application.cc
@@ -184,14 +184,31 @@ static void StartAivmtSp() {
     // configured; the default build (PTT disabled) is unaffected. Forward raw
     // button events to the SP encounter state machine, which calls
     // start_listening on press and stop_listening on release.
-    static Button g_ptt_button((gpio_num_t)CONFIG_AIVMT_PTT_GPIO);
+    // long_press_time 600ms: a held "talk" press registers as press-down/up (PTT),
+    // NOT as a click, so a short click can safely mean "advance the SP phase".
+    static Button g_ptt_button((gpio_num_t)CONFIG_AIVMT_PTT_GPIO, false, 600);
     g_ptt_button.OnPressDown([]() {
         if (g_aivmt_sp) g_aivmt_sp->OnEvent(aivmt::SpEvent::kPttPress);
     });
     g_ptt_button.OnPressUp([]() {
         if (g_aivmt_sp) g_aivmt_sp->OnEvent(aivmt::SpEvent::kPttRelease);
     });
-    ESP_LOGI("AIVMT.Hook", "PTT button enabled on GPIO %d", CONFIG_AIVMT_PTT_GPIO);
+    // Short click advances the SP flow by the event natural to the current state:
+    // Consent->ConsentGiven, CaseBrief->BriefDone, Encounter->ProbeStart (done asking),
+    // ReasoningProbe->ProbeAnswered, Feedback->FeedbackShown (->Ended, exports encounter).
+    g_ptt_button.OnClick([]() {
+        if (!g_aivmt_sp) return;
+        switch (g_aivmt_sp->state()) {
+            case aivmt::SpState::kConsent:        g_aivmt_sp->OnEvent(aivmt::SpEvent::kConsentGiven); break;
+            case aivmt::SpState::kCaseBrief:      g_aivmt_sp->OnEvent(aivmt::SpEvent::kBriefDone); break;
+            case aivmt::SpState::kEncounter:      g_aivmt_sp->OnEvent(aivmt::SpEvent::kProbeStart); break;
+            case aivmt::SpState::kReasoningProbe: g_aivmt_sp->OnEvent(aivmt::SpEvent::kProbeAnswered); break;
+            case aivmt::SpState::kFeedback:       g_aivmt_sp->OnEvent(aivmt::SpEvent::kFeedbackShown); break;
+            default: break;
+        }
+    });
+    ESP_LOGI("AIVMT.Hook", "PTT button on GPIO %d (hold=talk, click=advance phase)",
+             CONFIG_AIVMT_PTT_GPIO);
 #endif
 
     g_aivmt_sp->Start();  // -> logs "AIVMT.SpSession: enter Consent"
