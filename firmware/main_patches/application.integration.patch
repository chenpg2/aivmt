diff --git a/main/application.cc b/main/application.cc
index f0145a5..a757f81 100644
--- a/main/application.cc
+++ b/main/application.cc
@@ -190,19 +190,21 @@ static void StartAivmtSp() {
     // ends the encounter and exports the accumulated transcript directly — decoupled from
     // the phase machine, so it captures the real conversation regardless of SP state.
     // A long-press does not trigger the board's volume-down OnClick, so there is no collision.
-    // GPIO 39 = VOLUME_DOWN, 47 = TOUCH on bread-compact-wifi (board config.h macros are not
-    // visible in this board-agnostic file, so the pins are written literally for this board).
-    static Button g_sp_export_button(GPIO_NUM_39, false, 1000);  // 1s long-press
+    // Single-button scheme on the BOOT key (the only button guaranteed present):
+    //   - short CLICK  -> base ToggleChatState() (start/stop the conversation; talk via VAD turns)
+    //   - LONG-PRESS   -> export the accumulated encounter (our handler below)
+    // A long-press does not fire the base boot OnClick, so the two coexist on GPIO0.
+    static Button g_sp_export_button(GPIO_NUM_0, false, 1000);  // BOOT, 1s long-press = export
     g_sp_export_button.OnLongPress([]() {
         if (!g_aivmt_sp || !g_sp_active) return;
         aivmt::SpTelemetry tel = g_aivmt_sp->telemetry().data();
         Application::GetInstance().Schedule([tel]() {
             ESP_LOGI("AIVMT.Hook", "manual export: %u turns", (unsigned)g_sp_transcript.size());
-            AivmtPostEncounter(tel, "{\"trigger\":\"voldown_longpress\"}");
+            AivmtPostEncounter(tel, "{\"trigger\":\"boot_longpress\"}");
         });
     });
     ESP_LOGI("AIVMT.Hook",
-             "SP: talk = board touch button (GPIO47); export = long-press VOLUME-DOWN (GPIO39)");
+             "SP: click BOOT = start/stop talk; LONG-PRESS BOOT (1s) = export encounter");
 #endif
 
     g_aivmt_sp->Start();  // -> logs "AIVMT.SpSession: enter Consent"
